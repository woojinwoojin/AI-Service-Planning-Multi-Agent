# LLM 설정 — 키가 없으면 자동으로 더미 모드로 동작합니다(3일 차 골격 검증용).
# 실제 Agent 구현(4~7일 차)부터 키를 채워 사용하세요.

# 사용할 LLM provider: anthropic | openai | dummy
LLM_PROVIDER=dummy

# 강제 더미 모드(키가 있어도 더미로 실행). 1이면 활성화.
USE_DUMMY=1

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
